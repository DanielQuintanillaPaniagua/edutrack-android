<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- Espaciado superior -->
        <View
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <!-- Logo: Edu (blanco) + Track (verde) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edu"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Track"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#4CAF50" />

        </LinearLayout>

        <!-- Subtítulo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Control de asistencia universitaria"
            android:textSize="14sp"
            android:textColor="#90CAF9"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <!-- Selecciona tu rol -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona tu rol"
            android:textSize="14sp"
            android:textColor="#B0BEC5"
            android:layout_marginBottom="16dp" />

        <!-- Tarjetas de rol -->
        <RadioGroup
            android:id="@+id/rgRol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Tarjeta Docente -->
            <LinearLayout
                android:id="@+id/cardDocente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_rol_docente"
                android:padding="18dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/docente_rol"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Docente"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gestiona asistencias de tus materias"
                        android:textSize="12sp"
                        android:textColor="#90CAF9" />

                </LinearLayout>

                <RadioButton
                    android:id="@+id/rbDocente"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#4FC3F7"
                    android:checked="true" />

            </LinearLayout>

            <!-- Tarjeta Estudiante -->
            <LinearLayout
                android:id="@+id/cardEstudiante"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_rol_estudiante"
                android:padding="18dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/alumno_rol"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estudiante"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Consulta tu asistencia y tu progreso"
                        android:textSize="12sp"
                        android:textColor="#A5D6A7" />

                </LinearLayout>

                <RadioButton
                    android:id="@+id/rbEstudiante"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#66BB6A" />

            </LinearLayout>

        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

        <!-- Botón Iniciar sesión -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Iniciar sesión"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#0D1B2A"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <!-- Link registro -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿No tienes cuenta? "
                android:textSize="13sp"
                android:textColor="#B0BEC5" />

            <TextView
                android:id="@+id/tvRegistro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Regístrate"
                android:textSize="13sp"
                android:textColor="#4FC3F7"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Logo universidad -->
        <View
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/logougb"
            android:scaleType="fitCenter"
            android:alpha="0.7" />

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>

</ScrollView>