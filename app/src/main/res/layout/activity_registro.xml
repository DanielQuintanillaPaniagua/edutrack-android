<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crear cuenta"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Completa tus datos para registrarte"
            android:textColor="#90CAF9"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp"/>

        <!-- Nombre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre completo"
            android:textColor="#90CAF9"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:backgroundTint="#4CAF50"
            android:inputType="textPersonName"
            android:layout_marginBottom="16dp"/>

        <!-- Correo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Correo institucional"
            android:textColor="#90CAF9"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etCorreo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:backgroundTint="#4CAF50"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="16dp"/>

        <!-- Carnet -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Carnet / Código"
            android:textColor="#90CAF9"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etCarnet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="16dp"/>

        <!-- Contraseña -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contraseña"
            android:textColor="#90CAF9"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mínimo 6 caracteres"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:backgroundTint="#4CAF50"
            android:inputType="textPassword"
            android:layout_marginBottom="24dp"/>

        <!-- Selector de rol -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona tu rol"
            android:textColor="#90CAF9"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rgRol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <RadioButton
                android:id="@+id/rbDocente"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Docente"
                android:textColor="#FFFFFF"
                android:buttonTint="#4CAF50"/>

            <RadioButton
                android:id="@+id/rbEstudiante"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Estudiante"
                android:textColor="#FFFFFF"
                android:buttonTint="#4CAF50"/>

        </RadioGroup>

        <!-- Botón registrarse -->
        <Button
            android:id="@+id/btnRegistrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crear cuenta"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <!-- Volver al login -->
        <TextView
            android:id="@+id/tvYaTengosCuenta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¿Ya tienes cuenta? Inicia sesión"
            android:textColor="#90CAF9"
            android:textSize="13sp"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>