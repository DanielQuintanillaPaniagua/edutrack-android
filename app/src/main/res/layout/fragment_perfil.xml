<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Foto y nombre -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/imgPerfil"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@mipmap/ic_launcher_round"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ana García López"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Docente"
                android:textColor="#4CAF50"
                android:textSize="13sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ana.garcia@universidad.edu"
                android:textColor="#90CAF9"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Opciones del perfil -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A2A3A"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="👤  Información personal"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A3A4A"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🔒  Cambiar contraseña"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A3A4A"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🔔  Notificaciones"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A3A4A"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="⚙️  Preferencias"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A3A4A"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="❓  Ayuda y soporte"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Cerrar sesión -->
        <Button
            android:id="@+id/btnCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Cerrar sesión"
            android:backgroundTint="#FF5252"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>